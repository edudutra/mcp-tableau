# Credenciais e destino do Tableau (obrigatórias, exceto TABLEAU_SITE)
# Autenticação via Personal Access Token (PAT). Nunca commite valores reais.
TABLEAU_SERVER_URL=https://your-tableau-server.example.com
# Site content URL. Vazio = site default (Tableau Server). Obrigatório no Cloud.
TABLEAU_SITE=
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_SECRET=your-pat-secret

# Tempo limite das requisições à API, em segundos (opcional, default 30)
TABLEAU_TIMEOUT=30

# CA bundle opcional para verificação TLS em redes com CA corporativa própria.
# Caminho para um arquivo PEM; vazio = usa o store padrão do certifi.
# Ex.: /etc/ssl/certs/ca-certificates.crt
TABLEAU_CA_BUNDLE=

# Limiares de complexidade para auditoria de boas práticas (opcionais)
MAX_FILTERS=15
MAX_WORKSHEETS=20
MAX_DATA_SOURCES=5

# Limiares de volume das operações Hyper (Capacidade 5, opcionais). Exceder um
# limiar gera alerta não bloqueante, nunca bloqueio.
HYPER_MAX_SOURCE_FILE_MB=500
HYPER_MAX_INLINE_ROWS=1000
HYPER_MAX_RESULT_ROWS=200
HYPER_MAX_EXTRACT_ROWS=5000000

# Conexões de banco externo para extract_database_to_hyper (Capacidade 5).
# Uma variável por conexão nomeada: HYPER_DB_CONN_<NOME> (NOME em maiúsculas).
# O valor é uma connection string SQLAlchemy; o driver correspondente
# (psycopg, pymssql, oracledb, etc.) deve ser instalado no host pelo
# administrador. As credenciais NUNCA são parâmetro das tools — só o nome lógico.
# Ex.: a tool chamada com connection_name="VENDAS" lê HYPER_DB_CONN_VENDAS.
# HYPER_DB_CONN_VENDAS=postgresql+psycopg://usuario:senha@host:5432/base
