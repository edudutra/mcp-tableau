# Credenciais e destino do Tableau (obrigatórias, exceto TABLEAU_SITE)
# Autenticação via Personal Access Token (PAT). Nunca commite valores reais.
TABLEAU_SERVER_URL=https://your-tableau-server.example.com
# Site content URL. Vazio = site default (Tableau Server). Obrigatório no Cloud.
TABLEAU_SITE=
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_SECRET=your-pat-secret

# Tempo limite das requisições à API, em segundos (opcional, default 30)
TABLEAU_TIMEOUT=30

# CA bundle opcional para verificação TLS em redes com CA corporativa própria.
# Caminho para um arquivo PEM; vazio = usa o store padrão do certifi.
# Ex.: /etc/ssl/certs/ca-certificates.crt
TABLEAU_CA_BUNDLE=

# Limiares de complexidade para auditoria de boas práticas (opcionais)
MAX_FILTERS=15
MAX_WORKSHEETS=20
MAX_DATA_SOURCES=5
